{
  "manifest_version": 3,
  "name": "PDF to Markdown Converter",
  "version": "1.0.0",
  "description": "Convert PDF files to Markdown — single files or entire folders, batch conversion",
  "action": {
    "default_title": "PDF to Markdown",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["downloads"],
  "background": {
    "scripts": ["background/background.js"],
    "service_worker": "background/background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "pdf2md@deepanshu",
      "strict_min_version": "113.0"
    }
  }
}
